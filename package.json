{
  "name": "skillhub",
  "version": "0.1.0",
  "private": true,
  "description": "SkillHub monorepo: web registry, API and CLI for AI skills.",
  "packageManager": "pnpm@10.28.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter @skillhub/web dev",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck"
  },
  "keywords": ["ai", "skills", "registry", "cli"],
  "license": "MIT",
  "devDependencies": {
    "next": "^15.0.0"
  }
}
